# =====================================================
# FCD Tamil Nadu Platform — Environment Variables
# Copy this to .env and fill in your values
# =====================================================

# --- PostgreSQL / PostGIS ---
POSTGRES_DB=fcd
POSTGRES_USER=fcd_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://fcd_admin:change_me_in_production@db:5432/fcd

# --- Redis (job queue) ---
REDIS_URL=redis://redis:6379/0

# --- Object Storage (COG GeoTIFFs) ---
# Options: local | s3 | gcs
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/cogs
# AWS S3 (if STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=tn-fcd-cogs
# Google Cloud Storage (if STORAGE_BACKEND=gcs)
GCS_BUCKET=tn-fcd-cogs
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp_sa_key

# --- Sentinel-2 Data Source ---
# Options: stac_aws | copernicus_hub
SENTINEL_SOURCE=stac_aws
# Copernicus Dataspace credentials (if SENTINEL_SOURCE=copernicus_hub)
COPERNICUS_USER=
COPERNICUS_PASSWORD=

# --- API ---
API_SECRET_KEY=change_me_in_production
API_ALLOWED_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_TITILER_URL=http://localhost:8080
NEXT_PUBLIC_VECTOR_TILE_URL=http://localhost:7800
NEXT_PUBLIC_MAP_STYLE=https://demotiles.maplibre.org/style.json

# --- TiTiler ---
TITILER_CORS_ORIGINS=http://localhost:3000
