# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fcd_admin:fcd_password@db:5432/fcd

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── API Security ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=your-strong-random-secret-change-me

# Comma-separated list of allowed frontend origins
API_ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── TiTiler (raster tile server) ────────────────────────────────────────────
TITILER_URL=http://titiler:8080

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local          # local | s3 | gcs
STORAGE_LOCAL_PATH=/data/cogs
# S3_BUCKET=your-s3-bucket
# GCS_BUCKET=your-gcs-bucket

# ─── GitHub (for GeoTIFF release uploads & Releases API) ─────────────────────
GITHUB_REPO=Athithiyanmr/fcd-tamilnadu-platform
GITHUB_TOKEN=your_github_pat_here

# ─── Google Earth Engine (optional, legacy) ──────────────────────────────────
# GEE_PROJECT_ID=ee-athithiyan
# GEE_SERVICE_ACCOUNT_EMAIL=your-sa@ee-athithiyan.iam.gserviceaccount.com
# GEE_SERVICE_ACCOUNT_KEY={}
